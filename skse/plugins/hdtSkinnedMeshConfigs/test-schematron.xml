<system xmlns="FSMP-Validator">

	<!-- Default properties for dynamic bones -->
	<bone-default>
		<mass>1</mass>
		<inertia x="1" y="1" z="1"/>
		<linearDamping>0.02</linearDamping>
		<angularDamping>0.02</angularDamping>
	</bone-default>

